<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <item>
        <shape>
            <gradient
                android:angle="315"
                android:startColor="#33FFFFFF"
                android:centerColor="#151E2B3D"
                android:endColor="#10101824" />
            <stroke
                android:width="1dp"
                android:color="#44FFFFFF" />
            <corners android:radius="18dp" />
        </shape>
    </item>
    <item
        android:left="1dp"
        android:top="1dp"
        android:right="1dp"
        android:bottom="1dp">
        <shape>
            <gradient
                android:angle="135"
                android:startColor="#22FFFFFF"
                android:centerColor="#0717283A"
                android:endColor="#0017283A" />
            <corners android:radius="17dp" />
        </shape>
    </item>
</layer-list>
