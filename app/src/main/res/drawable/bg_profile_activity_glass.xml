<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <item>
        <shape>
            <gradient
                android:angle="315"
                android:startColor="#26314A68"
                android:centerColor="#18223736"
                android:endColor="#1015212F" />
            <stroke
                android:width="1dp"
                android:color="#2EFFFFFF" />
            <corners android:radius="12dp" />
        </shape>
    </item>
    <item
        android:left="1dp"
        android:top="1dp"
        android:right="1dp"
        android:bottom="1dp">
        <shape>
            <gradient
                android:angle="135"
                android:startColor="#1CFFFFFF"
                android:endColor="#00101824" />
            <corners android:radius="11dp" />
        </shape>
    </item>
</layer-list>
