<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <item>
        <shape>
            <gradient
                android:angle="135"
                android:endColor="#FFFFFF"
                android:startColor="#ECFDF5"
                android:type="linear" />
            <corners android:radius="20dp" />
        </shape>
    </item>
    <item android:gravity="right|top">
        <shape>
            <size
                android:width="118dp"
                android:height="118dp" />
            <gradient
                android:angle="315"
                android:endColor="#00FFFFFF"
                android:startColor="#2EE53E3E" />
            <corners
                android:bottomLeftRadius="118dp"
                android:topRightRadius="20dp" />
        </shape>
    </item>
    <item android:gravity="left|bottom">
        <shape>
            <size
                android:width="180dp"
                android:height="10dp" />
            <solid android:color="@color/premium_gold" />
            <corners android:radius="10dp" />
        </shape>
    </item>
    <item>
        <shape>
            <solid android:color="@color/transparent" />
            <stroke
                android:width="1dp"
                android:color="@color/colorOutline" />
            <corners android:radius="20dp" />
        </shape>
    </item>
</layer-list>
