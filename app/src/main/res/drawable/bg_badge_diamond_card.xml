<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <item>
        <shape>
            <gradient
                android:angle="0"
                android:endColor="#FFFFFF"
                android:startColor="@color/badge_diamond_soft" />
            <corners android:radius="18dp" />
        </shape>
    </item>
    <item android:gravity="right|top">
        <shape>
            <size
                android:width="96dp"
                android:height="96dp" />
            <gradient
                android:angle="315"
                android:endColor="#00FFFFFF"
                android:startColor="#660891B2" />
            <corners
                android:bottomLeftRadius="96dp"
                android:topRightRadius="18dp" />
        </shape>
    </item>
    <item>
        <shape>
            <solid android:color="@color/transparent" />
            <stroke
                android:width="1dp"
                android:color="@color/badge_diamond" />
            <corners android:radius="18dp" />
        </shape>
    </item>
</layer-list>
