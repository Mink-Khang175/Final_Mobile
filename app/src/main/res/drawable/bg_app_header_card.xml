<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <item>
        <shape>
            <solid android:color="#FFFFFFFF" />
            <stroke
                android:width="1dp"
                android:color="#E2E8F0" />
            <corners android:radius="10dp" />
        </shape>
    </item>
    <item
        android:left="0dp"
        android:width="126dp">
        <shape>
            <gradient
                android:angle="0"
                android:centerColor="#1AE53E3E"
                android:endColor="#00FFFFFF"
                android:startColor="#26E53E3E" />
            <corners
                android:bottomLeftRadius="10dp"
                android:topLeftRadius="10dp" />
        </shape>
    </item>
    <item
        android:left="104dp"
        android:width="34dp">
        <shape>
            <solid android:color="#16E53E3E" />
        </shape>
    </item>
    <item
        android:bottom="0dp"
        android:height="2dp">
        <shape>
            <gradient
                android:angle="0"
                android:endColor="@color/orange_spark"
                android:startColor="@color/red_energy" />
            <corners
                android:bottomLeftRadius="10dp"
                android:bottomRightRadius="10dp" />
        </shape>
    </item>
</layer-list>
