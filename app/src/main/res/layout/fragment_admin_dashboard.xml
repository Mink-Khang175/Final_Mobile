<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_home_premium_screen">

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:clipToPadding="false"
        android:fillViewport="true"
        android:paddingBottom="34dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <include
                android:id="@+id/appHeader"
                layout="@layout/component_app_header" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="20dp"
                android:layout_marginTop="18dp"
                android:background="@drawable/bg_admin_hero"
                android:orientation="vertical"
                android:padding="20dp">

                <TextView
                    android:id="@+id/tvAdminRole"
                    android:layout_width="wrap_content"
                    android:layout_height="28dp"
                    android:background="@drawable/bg_home_live_pill"
                    android:gravity="center"
                    android:paddingHorizontal="12dp"
                    android:text="QUẢN TRỊ"
                    android:textColor="@color/white"
                    android:textSize="11sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/tvAdminTitle"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="14dp"
                    android:text="Bảng quản trị"
                    android:textColor="@color/white"
                    android:textSize="28sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/tvAdminSubtitle"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:lineSpacingExtra="4dp"
                    android:text="Quản lý người dùng, đơn hàng, sản phẩm và cấu hình ứng dụng."
                    android:textColor="@color/white_alpha_80"
                    android:textSize="14sp" />

                <TextView
                    android:id="@+id/tvAdminEmail"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:ellipsize="end"
                    android:maxLines="1"
                    android:textColor="@color/white_alpha_70"
                    android:textSize="12sp" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="20dp"
                android:layout_marginTop="24dp"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <View
                    android:layout_width="4dp"
                    android:layout_height="22dp"
                    android:background="@drawable/bg_home_section_indicator" />

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="8dp"
                    android:layout_weight="1"
                    android:fontFamily="sans-serif-condensed"
                    android:includeFontPadding="false"
                    android:letterSpacing="0"
                    android:text="Tổng quan vận hành"
                    android:textColor="@color/stadium_ink"
                    android:textSize="23sp"
                    android:textStyle="bold|italic" />
            </LinearLayout>

            <GridLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="20dp"
                android:layout_marginTop="12dp"
                android:columnCount="2"
                android:useDefaultMargins="false">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="112dp"
                    android:layout_columnWeight="1"
                    android:layout_marginEnd="6dp"
                    android:layout_marginBottom="12dp"
                    android:background="@drawable/bg_admin_metric_card"
                    android:elevation="2dp"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="NGƯỜI DÙNG"
                        android:textColor="@color/slate_caption"
                        android:textSize="11sp"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/tvTotalUsers"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="10dp"
                        android:text="--"
                        android:textColor="@color/stadium_ink"
                        android:textSize="28sp"
                        android:textStyle="bold" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="112dp"
                    android:layout_columnWeight="1"
                    android:layout_marginStart="6dp"
                    android:layout_marginBottom="12dp"
                    android:background="@drawable/bg_admin_metric_card"
                    android:elevation="2dp"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="ĐƠN HÀNG"
                        android:textColor="@color/slate_caption"
                        android:textSize="11sp"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/tvTotalOrders"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="10dp"
                        android:text="--"
                        android:textColor="@color/stadium_ink"
                        android:textSize="28sp"
                        android:textStyle="bold" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="112dp"
                    android:layout_columnWeight="1"
                    android:layout_marginEnd="6dp"
                    android:background="@drawable/bg_admin_metric_card"
                    android:elevation="2dp"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="SẢN PHẨM"
                        android:textColor="@color/slate_caption"
                        android:textSize="11sp"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/tvProductCount"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="10dp"
                        android:text="--"
                        android:textColor="@color/red_energy"
                        android:textSize="28sp"
                        android:textStyle="bold" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="112dp"
                    android:layout_columnWeight="1"
                    android:layout_marginStart="6dp"
                    android:background="@drawable/bg_admin_metric_card"
                    android:elevation="2dp"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="DOANH THU"
                        android:textColor="@color/slate_caption"
                        android:textSize="11sp"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/tvTotalRevenue"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="10dp"
                        android:maxLines="1"
                        android:text="--"
                        android:textColor="@color/red_energy"
                        android:textSize="20sp"
                        android:textStyle="bold" />
                </LinearLayout>
            </GridLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="20dp"
                android:layout_marginTop="24dp"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <View
                    android:layout_width="4dp"
                    android:layout_height="22dp"
                    android:background="@drawable/bg_home_section_indicator" />

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="8dp"
                    android:layout_weight="1"
                    android:fontFamily="sans-serif-condensed"
                    android:includeFontPadding="false"
                    android:letterSpacing="0"
                    android:text="Chức năng quản trị"
                    android:textColor="@color/stadium_ink"
                    android:textSize="23sp"
                    android:textStyle="bold|italic" />
            </LinearLayout>

            <GridLayout
                android:id="@+id/gridModules"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="20dp"
                android:layout_marginTop="12dp"
                android:columnCount="2">

                <include
                    android:id="@+id/cardUsers"
                    layout="@layout/item_admin_module_card"
                    android:layout_width="0dp"
                    android:layout_height="128dp"
                    android:layout_columnWeight="1"
                    android:layout_marginEnd="6dp"
                    android:layout_marginBottom="12dp" />

                <include
                    android:id="@+id/cardOrders"
                    layout="@layout/item_admin_module_card"
                    android:layout_width="0dp"
                    android:layout_height="128dp"
                    android:layout_columnWeight="1"
                    android:layout_marginStart="6dp"
                    android:layout_marginBottom="12dp" />

                <include
                    android:id="@+id/cardProducts"
                    layout="@layout/item_admin_module_card"
                    android:layout_width="0dp"
                    android:layout_height="128dp"
                    android:layout_columnWeight="1"
                    android:layout_marginEnd="6dp"
                    android:layout_marginBottom="12dp" />

                <include
                    android:id="@+id/cardMissingProducts"
                    layout="@layout/item_admin_module_card"
                    android:layout_width="0dp"
                    android:layout_height="128dp"
                    android:layout_columnWeight="1"
                    android:layout_marginStart="6dp"
                    android:layout_marginBottom="12dp" />

                <include
                    android:id="@+id/cardBanners"
                    layout="@layout/item_admin_module_card"
                    android:layout_width="0dp"
                    android:layout_height="128dp"
                    android:layout_columnWeight="1"
                    android:layout_marginEnd="6dp"
                    android:layout_marginBottom="12dp" />

                <include
                    android:id="@+id/cardNotifications"
                    layout="@layout/item_admin_module_card"
                    android:layout_width="0dp"
                    android:layout_height="128dp"
                    android:layout_columnWeight="1"
                    android:layout_marginStart="6dp"
                    android:layout_marginBottom="12dp" />

                <include
                    android:id="@+id/cardAppSettings"
                    layout="@layout/item_admin_module_card"
                    android:layout_width="0dp"
                    android:layout_height="128dp"
                    android:layout_columnWeight="1"
                    android:layout_marginEnd="6dp" />

                <include
                    android:id="@+id/cardDataSync"
                    layout="@layout/item_admin_module_card"
                    android:layout_width="0dp"
                    android:layout_height="128dp"
                    android:layout_columnWeight="1"
                    android:layout_marginStart="6dp"
                    android:visibility="gone" />
            </GridLayout>

            <LinearLayout
                android:id="@+id/layoutMissingProducts"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="20dp"
                android:layout_marginTop="18dp"
                android:background="@drawable/bg_admin_module_card"
                android:elevation="2dp"
                android:orientation="vertical"
                android:padding="18dp">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="CLB thiếu sản phẩm"
                    android:textColor="@color/stadium_ink"
                    android:textSize="18sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/tvMissingProductsList"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:lineSpacingExtra="6dp"
                    android:text="Đang kiểm tra sản phẩm..."
                    android:textColor="@color/dark_gray_text"
                    android:textSize="14sp" />
            </LinearLayout>

            <TextView
                android:id="@+id/tvAdminNotes"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="20dp"
                android:layout_marginTop="16dp"
                android:background="@drawable/bg_admin_module_card"
                android:elevation="2dp"
                android:lineSpacingExtra="5dp"
                android:padding="18dp"
                    android:text=""
                android:textColor="@color/stadium_ink"
                android:textSize="14sp"
                android:visibility="gone" />

            <TextView
                android:id="@+id/btnAdminLogout"
                android:layout_width="match_parent"
                android:layout_height="54dp"
                android:layout_marginHorizontal="20dp"
                android:layout_marginTop="18dp"
                android:background="@drawable/bg_order_red_button"
                android:gravity="center"
                android:text="ĐĂNG XUẤT ADMIN"
                android:textColor="@color/white"
                android:textSize="13sp"
                android:textStyle="bold" />
        </LinearLayout>
    </androidx.core.widget.NestedScrollView>
</FrameLayout>

