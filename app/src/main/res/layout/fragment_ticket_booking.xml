<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_screen_field">

    <androidx.core.widget.NestedScrollView
        android:id="@+id/bookingScroll"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:clipToPadding="false"
        android:fillViewport="true"
        android:overScrollMode="never"
        android:paddingBottom="18dp"
        app:layout_constraintBottom_toTopOf="@id/bookingActionPanel"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingBottom="24dp">

            <include
                android:id="@+id/appHeader"
                layout="@layout/component_app_header" />

            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="174dp"
                android:layout_marginHorizontal="20dp"
                android:layout_marginTop="16dp"
                app:cardBackgroundColor="@color/premium_card"
                app:cardCornerRadius="22dp"
                app:cardElevation="6dp"
                app:strokeWidth="0dp">

                <FrameLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent">

                    <ImageView
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:scaleType="centerCrop"
                        android:src="@drawable/svd" />

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:background="@drawable/bg_shop_hero_scrim" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:gravity="bottom"
                        android:orientation="vertical"
                        android:padding="18dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:background="@drawable/bg_shop_orange_pill"
                            android:paddingHorizontal="11dp"
                            android:paddingVertical="5dp"
                            android:text="V.LEAGUE TICKET"
                            android:textColor="@color/white"
                            android:textSize="11sp"
                            android:textStyle="bold" />

                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="10dp"
                            android:fontFamily="sans-serif-condensed"
                            android:includeFontPadding="false"
                            android:text="Đặt vé xem bóng đá"
                            android:textColor="@color/white"
                            android:textSize="28sp"
                            android:textStyle="bold|italic" />

                        <TextView
                            android:id="@+id/tvBookingHeroSubtitle"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="6dp"
                            android:maxLines="2"
                            android:text="Chọn sân vận động, trận đấu, ghế ngồi và thanh toán QR."
                            android:textColor="@color/white_alpha_80"
                            android:textSize="14sp" />
                    </LinearLayout>
                </FrameLayout>
            </com.google.android.material.card.MaterialCardView>

            <TextView
                android:id="@+id/btnBackToShop"
                android:layout_width="wrap_content"
                android:layout_height="38dp"
                android:layout_marginStart="20dp"
                android:layout_marginTop="14dp"
                android:background="@drawable/bg_product_size_unselected"
                android:gravity="center"
                android:paddingHorizontal="14dp"
                android:text="Quay lại shop"
                android:textColor="@color/stadium_ink"
                android:textSize="13sp"
                android:textStyle="bold" />

            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="20dp"
                android:layout_marginTop="14dp"
                app:cardBackgroundColor="@color/premium_card"
                app:cardCornerRadius="20dp"
                app:cardElevation="4dp"
                app:strokeColor="@color/gray_border"
                app:strokeWidth="1dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="1. Chọn thành phố"
                        android:textColor="@color/dark_icon"
                        android:textSize="18sp"
                        android:textStyle="bold" />

                    <HorizontalScrollView
                        android:layout_width="match_parent"
                        android:layout_height="48dp"
                        android:layout_marginTop="12dp"
                        android:scrollbars="none">

                        <LinearLayout
                            android:id="@+id/layoutCityChips"
                            android:layout_width="wrap_content"
                            android:layout_height="match_parent"
                            android:gravity="center_vertical"
                            android:orientation="horizontal" />
                    </HorizontalScrollView>

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="16dp"
                        android:text="2. Chọn sân vận động"
                        android:textColor="@color/dark_icon"
                        android:textSize="18sp"
                        android:textStyle="bold" />

                    <LinearLayout
                        android:id="@+id/layoutVenueChips"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="12dp"
                        android:orientation="vertical" />

                    <TextView
                        android:id="@+id/tvVenueAddress"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="12dp"
                        android:background="@drawable/bg_auth_field"
                        android:padding="12dp"
                        android:textColor="@color/dark_gray_text"
                        android:textSize="13sp"
                        tools:text="Hang Day, Ha Noi" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="20dp"
                android:layout_marginTop="14dp"
                app:cardBackgroundColor="@color/premium_card"
                app:cardCornerRadius="20dp"
                app:cardElevation="4dp"
                app:strokeColor="@color/gray_border"
                app:strokeWidth="1dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="3. Chọn trận đấu"
                        android:textColor="@color/dark_icon"
                        android:textSize="18sp"
                        android:textStyle="bold" />

                    <HorizontalScrollView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="12dp"
                        android:clipToPadding="false"
                        android:overScrollMode="never"
                        android:scrollbars="none">

                        <LinearLayout
                            android:id="@+id/layoutRoundChips"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal" />
                    </HorizontalScrollView>

                    <ProgressBar
                        android:id="@+id/progressMatches"
                        android:layout_width="34dp"
                        android:layout_height="34dp"
                        android:layout_gravity="center_horizontal"
                        android:layout_marginTop="14dp"
                        android:visibility="gone" />

                    <TextView
                        android:id="@+id/tvMatchEmpty"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="12dp"
                        android:background="@drawable/bg_auth_field"
                        android:gravity="center"
                        android:padding="14dp"
                        android:text="Đang tải lịch thi đấu..."
                        android:textColor="@color/dark_gray_text"
                        android:textSize="13sp" />

                    <androidx.recyclerview.widget.RecyclerView
                        android:id="@+id/rvMatchCards"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="12dp"
                        android:clipToPadding="false"
                        android:overScrollMode="never" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="20dp"
                android:layout_marginTop="14dp"
                app:cardBackgroundColor="@color/premium_card"
                app:cardCornerRadius="20dp"
                app:cardElevation="4dp"
                app:strokeColor="@color/gray_border"
                app:strokeWidth="1dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <TextView
                        android:id="@+id/tvSeatSectionTitle"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="4. Chọn ghế"
                        android:textColor="@color/dark_icon"
                        android:textSize="18sp"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/tvSelectedMatch"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="6dp"
                        android:text="Chọn trận đấu để mở sơ đồ ghế."
                        android:textColor="@color/dark_gray_text"
                        android:textSize="13sp" />

                    <com.finalproject.v_league_ticket.presentation.booking.StadiumSeatMapView
                        android:id="@+id/seatMapView"
                        android:layout_width="match_parent"
                        android:layout_height="500dp"
                        android:layout_marginTop="14dp"
                        android:background="@drawable/bg_auth_field" />

                    <LinearLayout
                        android:id="@+id/layoutSeatZoom"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="10dp"
                        android:gravity="center_vertical"
                        android:orientation="horizontal">

                        <TextView
                            android:id="@+id/tvSeatZoomLabel"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Thu phóng"
                            android:textColor="@color/dark_icon"
                            android:textSize="12sp"
                            android:textStyle="bold" />

                        <SeekBar
                            android:id="@+id/seekSeatZoom"
                            android:layout_width="0dp"
                            android:layout_height="36dp"
                            android:layout_marginStart="10dp"
                            android:layout_weight="1"
                            android:max="100"
                            android:progress="20" />

                        <TextView
                            android:id="@+id/tvSeatZoomValue"
                            android:layout_width="44dp"
                            android:layout_height="wrap_content"
                            android:gravity="end"
                            android:text="100%"
                            android:textColor="@color/dark_gray_text"
                            android:textSize="12sp"
                            android:textStyle="bold" />
                    </LinearLayout>

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="12dp"
                        android:text="Chú giải màu ghế"
                        android:textColor="@color/dark_icon"
                        android:textSize="13sp"
                        android:textStyle="bold" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:orientation="vertical">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:baselineAligned="false"
                            android:orientation="horizontal">

                            <TextView
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_marginEnd="8dp"
                                android:layout_weight="1"
                                android:text="■ VIP - ghế khu A"
                                android:textColor="@color/orange_spark"
                                android:textSize="12sp"
                                android:textStyle="bold" />

                            <TextView
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:text="■ Thường - khu B/C/D"
                                android:textColor="#3B82F6"
                                android:textSize="12sp"
                                android:textStyle="bold" />
                        </LinearLayout>

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="6dp"
                            android:baselineAligned="false"
                            android:orientation="horizontal">

                            <TextView
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_marginEnd="8dp"
                                android:layout_weight="1"
                                android:text="■ Đang chọn - đã giữ chỗ"
                                android:textColor="@color/green_turf"
                                android:textSize="12sp"
                                android:textStyle="bold" />

                            <TextView
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:text="■ Đã bán/đang giữ"
                                android:textColor="@color/dark_gray_text"
                                android:textSize="12sp"
                                android:textStyle="bold" />
                        </LinearLayout>
                    </LinearLayout>

                    <TextView
                        android:id="@+id/tvSeatHoldTimer"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="12dp"
                        android:text="Giữ chỗ: --:--"
                        android:textColor="@color/shop_dynamic_red"
                        android:textSize="13sp"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/tvSelectedSeats"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:background="@drawable/bg_auth_field"
                        android:lineSpacingExtra="4dp"
                        android:padding="12dp"
                        android:text="Chưa chọn ghế."
                        android:textColor="@color/dark_gray_text"
                        android:textSize="13sp" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="20dp"
                android:layout_marginTop="14dp"
                app:cardBackgroundColor="@color/premium_card"
                app:cardCornerRadius="20dp"
                app:cardElevation="4dp"
                app:strokeColor="@color/gray_border"
                app:strokeWidth="1dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="5. Thông tin &amp; thanh toán"
                        android:textColor="@color/dark_icon"
                        android:textSize="18sp"
                        android:textStyle="bold" />

                    <com.google.android.material.textfield.TextInputLayout
                        android:id="@+id/tilTicketName"
                        style="@style/AuthTextInputLayout"
                        android:layout_marginTop="14dp"
                        android:hint="Họ và tên"
                        app:startIconDrawable="@drawable/ic_person_24">

                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/edtTicketName"
                            style="@style/AuthTextInputEditText"
                            android:inputType="textPersonName" />
                    </com.google.android.material.textfield.TextInputLayout>

                    <com.google.android.material.textfield.TextInputLayout
                        android:id="@+id/tilTicketPhone"
                        style="@style/AuthTextInputLayout"
                        android:layout_marginTop="12dp"
                        android:hint="Số điện thoại"
                        app:startIconDrawable="@drawable/ic_phone_24">

                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/edtTicketPhone"
                            style="@style/AuthTextInputEditText"
                            android:inputType="phone" />
                    </com.google.android.material.textfield.TextInputLayout>

                    <com.google.android.material.textfield.TextInputLayout
                        android:id="@+id/tilTicketEmail"
                        style="@style/AuthTextInputLayout"
                        android:layout_marginTop="12dp"
                        android:hint="Email nhận vé"
                        app:startIconDrawable="@drawable/ic_email_24">

                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/edtTicketEmail"
                            style="@style/AuthTextInputEditText"
                            android:inputType="textEmailAddress" />
                    </com.google.android.material.textfield.TextInputLayout>

                    <RadioGroup
                        android:id="@+id/rgTicketPayment"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="14dp"
                        android:orientation="horizontal"
                        android:weightSum="2">

                        <RadioButton
                            android:id="@+id/rbTicketVietinBank"
                            android:layout_width="0dp"
                            android:layout_height="48dp"
                            android:layout_weight="1"
                            android:buttonTint="@color/shop_dynamic_red"
                            android:checked="true"
                            android:text="VietinBank"
                            android:textColor="@color/dark_icon"
                            android:textSize="13sp"
                            android:textStyle="bold" />

                        <RadioButton
                            android:id="@+id/rbTicketMomo"
                            android:layout_width="0dp"
                            android:layout_height="48dp"
                            android:layout_weight="1"
                            android:buttonTint="@color/shop_dynamic_red"
                            android:text="MoMo"
                            android:textColor="@color/dark_icon"
                            android:textSize="13sp"
                            android:textStyle="bold" />
                    </RadioGroup>

                    <ImageView
                        android:id="@+id/imgTicketQr"
                        android:layout_width="176dp"
                        android:layout_height="176dp"
                        android:layout_gravity="center_horizontal"
                        android:layout_marginTop="8dp"
                        android:background="@color/white"
                        android:padding="8dp"
                        android:scaleType="fitCenter"
                        android:src="@drawable/qr_vietinbank" />

                    <CheckBox
                        android:id="@+id/cbTicketTerms"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:buttonTint="@color/shop_dynamic_red"
                        android:text="Tôi đồng ý với quy định đổi trả và soát vé của V.League."
                        android:textColor="@color/dark_gray_text"
                        android:textSize="13sp" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>
        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

    <com.google.android.material.card.MaterialCardView
        android:id="@+id/bookingActionPanel"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        app:cardBackgroundColor="@color/premium_card"
        app:cardCornerRadius="24dp"
        app:cardElevation="10dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:strokeWidth="0dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingHorizontal="20dp"
            android:paddingTop="14dp"
            android:paddingBottom="18dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Tổng thanh toán"
                    android:textColor="@color/dark_gray_text"
                    android:textSize="13sp" />

                <TextView
                    android:id="@+id/tvTicketTotal"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="--"
                    android:textColor="@color/shop_dynamic_red"
                    android:textSize="22sp"
                    android:textStyle="bold" />
            </LinearLayout>

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnConfirmTicketOrder"
                android:layout_width="match_parent"
                android:layout_height="54dp"
                android:layout_marginTop="10dp"
                android:text="Đặt vé"
                android:textAllCaps="false"
                android:textColor="@color/white"
                android:textSize="15sp"
                android:textStyle="bold"
                app:backgroundTint="@color/shop_dynamic_orange"
                app:cornerRadius="14dp"
                app:elevation="0dp" />
        </LinearLayout>
    </com.google.android.material.card.MaterialCardView>
</androidx.constraintlayout.widget.ConstraintLayout>
