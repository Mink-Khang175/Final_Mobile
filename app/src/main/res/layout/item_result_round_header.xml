<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginTop="6dp"
    android:layout_marginBottom="8dp"
    android:gravity="center_vertical"
    android:orientation="horizontal">

    <View
        android:layout_width="4dp"
        android:layout_height="20dp"
        android:background="@drawable/bg_home_section_indicator" />

    <TextView
        android:id="@+id/tvRoundTitle"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="10dp"
        android:layout_weight="1"
        android:fontFamily="sans-serif-condensed"
        android:includeFontPadding="false"
        android:letterSpacing="0"
        android:textColor="@color/stadium_ink"
        android:textSize="20sp"
        android:textStyle="bold|italic"
        tools:text="Round 26" />

    <TextView
        android:id="@+id/tvRoundCount"
        android:layout_width="wrap_content"
        android:layout_height="28dp"
        android:background="@drawable/bg_segment_active"
        android:gravity="center"
        android:minWidth="72dp"
        android:paddingHorizontal="12dp"
        android:textColor="@color/red_energy"
        android:textSize="11sp"
        android:textStyle="bold"
        tools:text="7 trận" />
</LinearLayout>
