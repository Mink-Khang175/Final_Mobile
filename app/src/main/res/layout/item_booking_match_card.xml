<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/cardBookingMatch"
    android:layout_width="230dp"
    android:layout_height="wrap_content"
    android:layout_marginEnd="10dp"
    android:background="@drawable/bg_shop_action_simple"
    android:clickable="true"
    android:focusable="true"
    android:foreground="?attr/selectableItemBackground"
    android:gravity="center_vertical"
    android:orientation="vertical"
    android:paddingHorizontal="12dp"
    android:paddingVertical="10dp">

    <TextView
        android:id="@+id/tvBookingMatchTitle"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:ellipsize="end"
        android:maxLines="2"
        android:textColor="@color/dark_icon"
        android:textSize="14sp"
        android:textStyle="bold"
        tools:text="Hà Nội FC vs Hải Phòng FC" />

    <TextView
        android:id="@+id/tvBookingMatchMeta"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="5dp"
        android:ellipsize="end"
        android:maxLines="3"
        android:textColor="@color/dark_gray_text"
        android:textSize="12sp"
        tools:text="08/08/2026 • 18:00&#10;Hàng Đẫy&#10;Từ 180.000đ" />
</LinearLayout>
