<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_screen_field">

    <androidx.core.widget.NestedScrollView
        android:id="@+id/checkoutScroll"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:clipToPadding="false"
        android:fillViewport="true"
        android:overScrollMode="never"
        android:paddingBottom="18dp"
        app:layout_constraintBottom_toTopOf="@id/orderActionPanel"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingHorizontal="20dp"
            android:paddingTop="22dp"
            android:paddingBottom="18dp">

            <TextView
                android:id="@+id/tvCheckoutTitle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Thanh toán"
                android:textColor="@color/dark_icon"
                android:textSize="28sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tvCheckoutSubtitle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="Hoàn tất thông tin đơn hàng trước khi đặt mua."
                android:textColor="@color/dark_gray_text"
                android:textSize="14sp" />

            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cardShippingInfo"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="20dp"
                app:cardBackgroundColor="@color/premium_card"
                app:cardCornerRadius="20dp"
                app:cardElevation="4dp"
                app:strokeColor="@color/gray_border"
                app:strokeWidth="1dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <TextView
                        android:id="@+id/tvShippingTitle"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Thông tin giao hàng"
                        android:textColor="@color/dark_icon"
                        android:textSize="18sp"
                        android:textStyle="bold" />

                    <com.google.android.material.textfield.TextInputLayout
                        android:id="@+id/tilFullName"
                        style="@style/AuthTextInputLayout"
                        android:layout_marginTop="16dp"
                        android:hint="Họ và tên"
                        app:startIconDrawable="@drawable/ic_person_24">

                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/edtFullName"
                            style="@style/AuthTextInputEditText"
                            android:inputType="textPersonName"
                            tools:text="Ho Minh Khang" />
                    </com.google.android.material.textfield.TextInputLayout>

                    <com.google.android.material.textfield.TextInputLayout
                        android:id="@+id/tilPhoneNumber"
                        style="@style/AuthTextInputLayout"
                        android:layout_marginTop="12dp"
                        android:hint="Số điện thoại"
                        app:startIconDrawable="@drawable/ic_phone_24">

                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/edtPhoneNumber"
                            style="@style/AuthTextInputEditText"
                            android:inputType="phone"
                            tools:text="0901234567" />
                    </com.google.android.material.textfield.TextInputLayout>

                    <com.google.android.material.textfield.TextInputLayout
                        android:id="@+id/tilDetailedAddress"
                        style="@style/AuthTextInputLayout"
                        android:layout_marginTop="12dp"
                        android:hint="Địa chỉ chi tiết"
                        app:startIconDrawable="@drawable/ic_location_24">

                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/edtDetailedAddress"
                            style="@style/AuthTextInputEditText"
                            android:inputType="textPostalAddress"
                            android:minLines="1"
                            tools:text="12 Nguyen Trai, District 1, HCMC" />
                    </com.google.android.material.textfield.TextInputLayout>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cardPaymentMethod"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="14dp"
                app:cardBackgroundColor="@color/premium_card"
                app:cardCornerRadius="20dp"
                app:cardElevation="4dp"
                app:strokeColor="@color/gray_border"
                app:strokeWidth="1dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <TextView
                        android:id="@+id/tvPaymentTitle"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Phương thức thanh toán"
                        android:textColor="@color/dark_icon"
                        android:textSize="18sp"
                        android:textStyle="bold" />

                    <RadioGroup
                        android:id="@+id/rgPaymentMethod"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="12dp"
                        android:orientation="vertical">

                        <RadioButton
                            android:id="@+id/rbCashOnDelivery"
                            android:layout_width="match_parent"
                            android:layout_height="54dp"
                            android:buttonTint="@color/shop_dynamic_red"
                            android:drawableStart="@drawable/ic_cash_24"
                            android:drawablePadding="12dp"
                            android:gravity="center_vertical"
                            android:paddingHorizontal="4dp"
                            android:text="Thanh toán khi nhận hàng"
                            android:textColor="@color/dark_icon"
                            android:textSize="15sp"
                            android:textStyle="bold"
                            tools:checked="true" />

                        <View
                            android:layout_width="match_parent"
                            android:layout_height="1dp"
                            android:background="@color/gray_border" />

                        <RadioButton
                            android:id="@+id/rbBankTransfer"
                            android:layout_width="match_parent"
                            android:layout_height="54dp"
                            android:buttonTint="@color/shop_dynamic_red"
                            android:drawableStart="@drawable/ic_transfer_24"
                            android:drawablePadding="12dp"
                            android:gravity="center_vertical"
                            android:paddingHorizontal="4dp"
                            android:text="Chuyển khoản"
                            android:textColor="@color/dark_icon"
                            android:textSize="15sp"
                            android:textStyle="bold" />
                    </RadioGroup>

                    <LinearLayout
                        android:id="@+id/layoutOnlinePayment"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="10dp"
                        android:background="@drawable/bg_auth_field"
                        android:orientation="vertical"
                        android:padding="12dp"
                        android:visibility="gone"
                        tools:visibility="visible">

                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="Chọn kênh chuyển khoản"
                            android:textColor="@color/dark_icon"
                            android:textSize="13sp"
                            android:textStyle="bold" />

                        <RadioGroup
                            android:id="@+id/rgOnlinePayment"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="8dp"
                            android:orientation="horizontal"
                            android:weightSum="2">

                            <RadioButton
                                android:id="@+id/rbVietinBank"
                                android:layout_width="0dp"
                                android:layout_height="48dp"
                                android:layout_weight="1"
                                android:buttonTint="@color/shop_dynamic_red"
                                android:text="VietinBank"
                                android:textColor="@color/dark_icon"
                                android:textSize="13sp"
                                android:textStyle="bold"
                                tools:checked="true" />

                            <RadioButton
                                android:id="@+id/rbMomo"
                                android:layout_width="0dp"
                                android:layout_height="48dp"
                                android:layout_weight="1"
                                android:buttonTint="@color/shop_dynamic_red"
                                android:text="MoMo"
                                android:textColor="@color/dark_icon"
                                android:textSize="13sp"
                                android:textStyle="bold" />
                        </RadioGroup>

                        <ImageView
                            android:id="@+id/imgPaymentQr"
                            android:layout_width="176dp"
                            android:layout_height="176dp"
                            android:layout_gravity="center_horizontal"
                            android:layout_marginTop="8dp"
                            android:background="@color/white"
                            android:padding="8dp"
                            android:scaleType="fitCenter"
                            android:src="@drawable/qr_vietinbank" />
                    </LinearLayout>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cardOrderSummary"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="14dp"
                app:cardBackgroundColor="@color/premium_card"
                app:cardCornerRadius="20dp"
                app:cardElevation="4dp"
                app:strokeColor="@color/gray_border"
                app:strokeWidth="1dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <TextView
                        android:id="@+id/tvOrderSummaryTitle"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Tóm tắt đơn hàng"
                        android:textColor="@color/dark_icon"
                        android:textSize="18sp"
                        android:textStyle="bold" />

                    <LinearLayout
                        android:id="@+id/rowSubtotal"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="16dp"
                        android:gravity="center_vertical"
                        android:orientation="horizontal">

                        <TextView
                            android:id="@+id/tvSubtotalLabel"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="Tạm tính"
                            android:textColor="@color/dark_gray_text"
                            android:textSize="14sp" />

                        <TextView
                            android:id="@+id/tvSubtotal"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:textColor="@color/dark_icon"
                            android:textSize="15sp"
                            android:textStyle="bold"
                            tools:text="1,500,000 đ" />
                    </LinearLayout>

                    <LinearLayout
                        android:id="@+id/rowShippingFee"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="12dp"
                        android:gravity="center_vertical"
                        android:orientation="horizontal">

                        <TextView
                            android:id="@+id/tvShippingFeeLabel"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="Phí giao hàng"
                            android:textColor="@color/dark_gray_text"
                            android:textSize="14sp" />

                        <TextView
                            android:id="@+id/tvShippingFee"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:textColor="@color/dark_icon"
                            android:textSize="15sp"
                            android:textStyle="bold"
                            tools:text="30,000 đ" />
                    </LinearLayout>

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:layout_marginTop="14dp"
                        android:background="@color/gray_border" />

                    <LinearLayout
                        android:id="@+id/rowFinalTotal"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="14dp"
                        android:gravity="center_vertical"
                        android:orientation="horizontal">

                        <TextView
                            android:id="@+id/tvFinalTotalLabel"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="Tổng thanh toán"
                            android:textColor="@color/dark_icon"
                            android:textSize="16sp"
                            android:textStyle="bold" />

                        <TextView
                            android:id="@+id/tvFinalTotal"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:textColor="@color/shop_dynamic_red"
                            android:textSize="22sp"
                            android:textStyle="bold"
                            tools:text="1,530,000 đ" />
                    </LinearLayout>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>
        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

    <com.google.android.material.card.MaterialCardView
        android:id="@+id/orderActionPanel"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        app:cardBackgroundColor="@color/premium_card"
        app:cardCornerRadius="24dp"
        app:cardElevation="10dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:strokeWidth="0dp">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnPlaceOrder"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:layout_marginHorizontal="20dp"
            android:layout_marginTop="16dp"
            android:layout_marginBottom="22dp"
            android:text="ĐẶT HÀNG"
            android:textAllCaps="false"
            android:textColor="@color/white"
            android:textSize="15sp"
            android:textStyle="bold"
            app:backgroundTint="@color/shop_dynamic_orange"
            app:cornerRadius="14dp"
            app:elevation="0dp" />
    </com.google.android.material.card.MaterialCardView>
</androidx.constraintlayout.widget.ConstraintLayout>
