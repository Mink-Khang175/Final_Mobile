<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="258dp"
    android:layout_height="wrap_content"
    android:layout_marginEnd="14dp"
    app:cardBackgroundColor="@color/premium_card"
    app:cardCornerRadius="24dp"
    app:cardElevation="4dp"
    app:cardUseCompatPadding="true">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="154dp"
        android:background="@drawable/bg_home_card_clean"
        android:padding="16dp">

        <TextView
            android:id="@+id/tvFixtureRound"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:ellipsize="end"
            android:maxLines="1"
            android:text="Vòng 1"
            android:textColor="@color/stadium_ink"
            android:textSize="11sp"
            android:textStyle="bold"
            app:layout_constraintEnd_toStartOf="@id/tvFixtureDate"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <TextView
            android:id="@+id/tvFixtureDate"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="26/10"
            android:textColor="@color/dark_gray_alpha_60"
            android:textSize="11sp"
            android:textStyle="bold"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <ImageView
            android:id="@+id/imgFixtureHomeLogo"
            android:layout_width="42dp"
            android:layout_height="42dp"
            android:layout_marginTop="18dp"
            android:background="@drawable/bg_home_story_ring"
            android:padding="6dp"
            android:scaleType="centerInside"
            android:src="@drawable/ic_logo"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/tvFixtureRound" />

        <TextView
            android:id="@+id/tvFixtureTime"
            android:layout_width="74dp"
            android:layout_height="38dp"
            android:background="@drawable/bg_home_fixture_time"
            android:gravity="center"
            android:text="19:15"
            android:textColor="@color/stadium_ink"
            android:textSize="18sp"
            android:textStyle="bold"
            app:layout_constraintBottom_toBottomOf="@id/imgFixtureHomeLogo"
            app:layout_constraintEnd_toStartOf="@id/imgFixtureAwayLogo"
            app:layout_constraintStart_toEndOf="@id/imgFixtureHomeLogo"
            app:layout_constraintTop_toTopOf="@id/imgFixtureHomeLogo" />

        <ImageView
            android:id="@+id/imgFixtureAwayLogo"
            android:layout_width="42dp"
            android:layout_height="42dp"
            android:background="@drawable/bg_home_story_ring"
            android:padding="6dp"
            android:scaleType="centerInside"
            android:src="@drawable/ic_logo"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="@id/imgFixtureHomeLogo" />

        <TextView
            android:id="@+id/tvFixtureHomeTeam"
            android:layout_width="76dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:ellipsize="end"
            android:gravity="center"
            android:maxLines="2"
            android:text="Nam Định"
            android:textColor="@color/stadium_ink"
            android:textSize="12sp"
            android:textStyle="bold"
            app:layout_constraintEnd_toEndOf="@id/imgFixtureHomeLogo"
            app:layout_constraintStart_toStartOf="@id/imgFixtureHomeLogo"
            app:layout_constraintTop_toBottomOf="@id/imgFixtureHomeLogo" />

        <TextView
            android:id="@+id/tvFixtureAwayTeam"
            android:layout_width="76dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:ellipsize="end"
            android:gravity="center"
            android:maxLines="2"
            android:text="Hà Nội"
            android:textColor="@color/stadium_ink"
            android:textSize="12sp"
            android:textStyle="bold"
            app:layout_constraintEnd_toEndOf="@id/imgFixtureAwayLogo"
            app:layout_constraintStart_toStartOf="@id/imgFixtureAwayLogo"
            app:layout_constraintTop_toBottomOf="@id/imgFixtureAwayLogo" />

        <TextView
            android:id="@+id/tvFixtureVenue"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:ellipsize="end"
            android:gravity="center"
            android:maxLines="1"
            android:text="Thiên Trường"
            android:textColor="@color/dark_gray_alpha_60"
            android:textSize="11sp"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent" />
    </androidx.constraintlayout.widget.ConstraintLayout>
</androidx.cardview.widget.CardView>

