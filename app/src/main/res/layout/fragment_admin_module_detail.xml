<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_home_premium_screen"
    android:orientation="vertical">

    <include
        android:id="@+id/appHeader"
        layout="@layout/component_app_header" />

    <TextView
        android:id="@+id/btnBackAdmin"
        android:layout_width="match_parent"
        android:layout_height="44dp"
        android:layout_marginHorizontal="20dp"
        android:layout_marginTop="16dp"
        android:background="@drawable/bg_admin_module_card"
        android:gravity="center_vertical"
        android:paddingHorizontal="16dp"
        android:text="VỀ QUẢN TRỊ"
        android:textColor="@color/stadium_ink"
        android:textSize="13sp"
        android:textStyle="bold" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="20dp"
        android:layout_marginTop="16dp"
        android:background="@drawable/bg_admin_hero"
        android:orientation="vertical"
        android:padding="20dp">

        <TextView
            android:id="@+id/tvModuleLabel"
            android:layout_width="wrap_content"
            android:layout_height="28dp"
            android:background="@drawable/bg_home_live_pill"
            android:gravity="center"
            android:paddingHorizontal="12dp"
            android:text="CHỨC NĂNG QUẢN TRỊ"
            android:textColor="@color/white"
            android:textSize="11sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/tvModuleTitle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="14dp"
            android:textColor="@color/white"
            android:textSize="26sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/tvModuleSubtitle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:lineSpacingExtra="4dp"
            android:textColor="@color/white_alpha_80"
            android:textSize="14sp" />
    </LinearLayout>

    <TextView
        android:id="@+id/btnRefresh"
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:layout_marginHorizontal="20dp"
        android:layout_marginTop="16dp"
        android:background="@drawable/bg_order_red_button"
        android:gravity="center"
        android:text="LÀM MỚI"
        android:textColor="@color/white"
        android:textSize="13sp"
        android:textStyle="bold" />

    <EditText
        android:id="@+id/edtAdminSearch"
        android:layout_width="match_parent"
        android:layout_height="46dp"
        android:layout_marginHorizontal="20dp"
        android:layout_marginTop="12dp"
        android:background="@drawable/bg_admin_module_card"
        android:hint="Tìm theo mã, khách hàng, email, CLB..."
        android:imeOptions="actionSearch"
        android:inputType="text"
        android:maxLines="1"
        android:paddingHorizontal="16dp"
        android:textColor="@color/stadium_ink"
        android:textColorHint="@color/slate_caption"
        android:textSize="13sp" />

    <TextView
        android:id="@+id/tvListState"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="20dp"
        android:layout_marginTop="16dp"
        android:background="@drawable/bg_admin_module_card"
        android:padding="18dp"
        android:textColor="@color/slate_caption"
        android:textSize="14sp"
        android:visibility="gone" />

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rvContent"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_marginHorizontal="20dp"
        android:layout_marginTop="16dp"
        android:layout_weight="1"
        android:clipToPadding="false"
        android:paddingBottom="34dp" />

    <TextView
        android:id="@+id/btnLoadMore"
        android:layout_width="match_parent"
        android:layout_height="46dp"
        android:layout_marginHorizontal="20dp"
        android:layout_marginBottom="16dp"
        android:background="@drawable/bg_order_outline_button"
        android:gravity="center"
        android:text="TẢI THÊM"
        android:textColor="@color/red_energy"
        android:textSize="13sp"
        android:textStyle="bold"
        android:visibility="gone" />
</LinearLayout>
