<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_app">

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:clipToPadding="false"
        android:fillViewport="true"
        android:overScrollMode="never"
        android:paddingBottom="150dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingHorizontal="22dp"
            android:paddingTop="34dp"
            android:paddingBottom="28dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="54dp"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <ImageView
                    android:id="@+id/imgReceiptLogo"
                    android:layout_width="58dp"
                    android:layout_height="40dp"
                    android:contentDescription="@string/app_name"
                    android:scaleType="centerInside"
                    android:src="@drawable/ic_logo" />

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="10dp"
                    android:layout_weight="1"
                    android:fontFamily="sans-serif-condensed"
                    android:includeFontPadding="false"
                    android:letterSpacing="0"
                    android:text="Xác nhận đơn"
                    android:textColor="@color/stadium_ink"
                    android:textSize="24sp"
                    android:textStyle="bold|italic" />
            </LinearLayout>

            <FrameLayout
                android:id="@+id/successIconContainer"
                android:layout_width="86dp"
                android:layout_height="86dp"
                android:layout_gravity="center_horizontal"
                android:layout_marginTop="20dp"
                android:background="@drawable/bg_success_big_icon"
                android:padding="20dp">

                <androidx.appcompat.widget.AppCompatImageView
                    android:id="@+id/tvSuccessIcon"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:contentDescription="@string/order_success_title"
                    android:src="@drawable/ic_check_circle_48"
                    app:tint="@color/pitch_green" />
            </FrameLayout>

            <TextView
                android:id="@+id/tvOrderSuccessTitle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:fontFamily="sans-serif-condensed"
                android:gravity="center"
                android:includeFontPadding="false"
                android:letterSpacing="0"
                android:textColor="@color/stadium_ink"
                android:textSize="31sp"
                android:textStyle="bold|italic"
                tools:text="Đặt hàng" />

            <TextView
                android:id="@+id/tvOrderSuccessSubtitle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:gravity="center"
                android:lineSpacingExtra="4dp"
                android:textColor="@color/slate_caption"
                android:textSize="14sp"
                tools:text="Đơn hàng đã được ghi nhận và đang chờ admin xác nhận thanh toán." />

            <TextView
                android:id="@+id/tvOrderSuccessHeadline"
                android:layout_width="wrap_content"
                android:layout_height="34dp"
                android:layout_gravity="center_horizontal"
                android:layout_marginTop="14dp"
                android:background="@drawable/bg_success_status_waiting"
                android:gravity="center"
                android:minWidth="138dp"
                android:paddingHorizontal="16dp"
                android:textColor="@color/stadium_ink"
                android:textSize="12sp"
                android:textStyle="bold"
                tools:text="Chờ xác nhận" />

            <com.google.android.material.card.MaterialCardView
                android:id="@+id/layoutSuccessContent"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="26dp"
                app:cardBackgroundColor="@color/white"
                app:cardCornerRadius="18dp"
                app:cardElevation="2dp"
                app:strokeColor="@color/colorOutline"
                app:strokeWidth="1dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="18dp">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Thông tin đơn"
                        android:textColor="@color/stadium_ink"
                        android:textSize="16sp"
                        android:textStyle="bold" />

                    <LinearLayout
                        android:id="@+id/cardOrderId"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="14dp"
                        android:background="@drawable/bg_success_order_code_modern"
                        android:gravity="center_vertical"
                        android:orientation="horizontal"
                        android:paddingHorizontal="14dp"
                        android:paddingVertical="14dp">

                        <androidx.appcompat.widget.AppCompatImageView
                            android:layout_width="38dp"
                            android:layout_height="38dp"
                            android:background="@drawable/bg_history_icon_order"
                            android:padding="9dp"
                            android:src="@drawable/ic_receipt_24"
                            app:tint="@color/red_energy" />

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="12dp"
                            android:layout_weight="1"
                            android:orientation="vertical">

                            <TextView
                                android:id="@+id/tvOrderLabel"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:textColor="@color/slate_caption"
                                android:textSize="12sp"
                                tools:text="Mã đơn" />

                            <TextView
                                android:id="@+id/tvOrderId"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="5dp"
                                android:ellipsize="middle"
                                android:maxLines="1"
                                android:textColor="@color/stadium_ink"
                                android:textSize="17sp"
                                android:textStyle="bold"
                                tools:text="ORD1783500990709" />
                        </LinearLayout>
                    </LinearLayout>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="14dp"
                app:cardBackgroundColor="@color/white"
                app:cardCornerRadius="18dp"
                app:cardElevation="2dp"
                app:strokeColor="@color/colorOutline"
                app:strokeWidth="1dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="18dp">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Tiến trình xử lý"
                        android:textColor="@color/stadium_ink"
                        android:textSize="16sp"
                        android:textStyle="bold" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="16dp"
                        android:gravity="center_vertical"
                        android:orientation="horizontal">

                        <View
                            android:layout_width="12dp"
                            android:layout_height="12dp"
                            android:background="@drawable/bg_success_step_dot_active" />

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="12dp"
                            android:layout_weight="1"
                            android:orientation="vertical">

                            <TextView
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:text="Đã ghi nhận"
                                android:textColor="@color/stadium_ink"
                                android:textSize="14sp"
                                android:textStyle="bold" />

                            <TextView
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="3dp"
                                android:text="Hệ thống đã lưu đơn của bạn."
                                android:textColor="@color/slate_caption"
                                android:textSize="12sp" />
                        </LinearLayout>
                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="14dp"
                        android:gravity="center_vertical"
                        android:orientation="horizontal">

                        <View
                            android:layout_width="12dp"
                            android:layout_height="12dp"
                            android:background="@drawable/bg_success_step_dot_pending" />

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="12dp"
                            android:layout_weight="1"
                            android:orientation="vertical">

                            <TextView
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:text="Chờ admin xác nhận"
                                android:textColor="@color/stadium_ink"
                                android:textSize="14sp"
                                android:textStyle="bold" />

                            <TextView
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="3dp"
                                android:text="Sau khi xác nhận, trạng thái sẽ cập nhật trong mục đơn hàng."
                                android:textColor="@color/slate_caption"
                                android:textSize="12sp" />
                        </LinearLayout>
                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="14dp"
                        android:gravity="center_vertical"
                        android:orientation="horizontal">

                        <View
                            android:layout_width="12dp"
                            android:layout_height="12dp"
                            android:background="@drawable/bg_success_step_dot_pending" />

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="12dp"
                            android:layout_weight="1"
                            android:orientation="vertical">

                            <TextView
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:text="Xử lý giao hàng / vé"
                                android:textColor="@color/stadium_ink"
                                android:textSize="14sp"
                                android:textStyle="bold" />

                            <TextView
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="3dp"
                                android:text="Bạn sẽ nhận thông báo khi có cập nhật mới."
                                android:textColor="@color/slate_caption"
                                android:textSize="12sp" />
                        </LinearLayout>
                    </LinearLayout>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>
        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

    <LinearLayout
        android:id="@+id/layoutSuccessActions"
        android:layout_width="match_parent"
        android:layout_height="132dp"
        android:layout_gravity="bottom"
        android:background="@drawable/bg_success_action_dock"
        android:elevation="12dp"
        android:orientation="vertical"
        android:paddingHorizontal="22dp"
        android:paddingTop="14dp"
        android:paddingBottom="18dp">

        <TextView
            android:id="@+id/btnTrackOrder"
            android:layout_width="match_parent"
            android:layout_height="50dp"
            android:background="@drawable/bg_success_primary_button"
            android:gravity="center"
            android:textColor="@color/white"
            android:textSize="13sp"
            android:textStyle="bold"
            tools:text="XEM ĐƠN HÀNG" />

        <TextView
            android:id="@+id/btnBackToHome"
            android:layout_width="match_parent"
            android:layout_height="46dp"
            android:layout_marginTop="8dp"
            android:background="@drawable/bg_success_secondary_button"
            android:gravity="center"
            android:textColor="@color/stadium_ink"
            android:textSize="13sp"
            android:textStyle="bold"
            tools:text="VỀ TRANG CHỦ" />
    </LinearLayout>
</FrameLayout>
