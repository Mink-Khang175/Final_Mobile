<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_screen_field">

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:clipToPadding="false"
        android:fillViewport="true"
        android:paddingBottom="180dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingBottom="28dp">

            <include
                android:id="@+id/appHeader"
                layout="@layout/component_app_header" />

            <LinearLayout
                android:id="@+id/layoutTabs"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:layout_marginHorizontal="20dp"
                android:layout_marginTop="20dp"
                android:background="@drawable/bg_segmented_tabs"
                android:orientation="horizontal"
                android:padding="4dp"
                android:weightSum="3">

                <TextView
                    android:id="@+id/tabFixtures"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:gravity="center"
                    android:text="LỊCH ĐẤU"
                    android:textColor="@color/dark_gray_text"
                    android:textSize="12sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/tabResults"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:gravity="center"
                    android:text="KẾT QUẢ"
                    android:textColor="@color/dark_gray_text"
                    android:textSize="12sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/tabStandings"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:background="@drawable/bg_segment_active"
                    android:gravity="center"
                    android:text="BXH"
                    android:textColor="@color/red_energy"
                    android:textSize="12sp"
                    android:textStyle="bold" />
            </LinearLayout>

            <HorizontalScrollView
                android:layout_width="match_parent"
                android:layout_height="46dp"
                android:layout_marginTop="14dp"
                android:clipToPadding="false"
                android:paddingStart="20dp"
                android:paddingEnd="20dp"
                android:scrollbars="none">

                <LinearLayout
                    android:id="@+id/seasonContainer"
                    android:layout_width="wrap_content"
                    android:layout_height="match_parent"
                    android:gravity="center_vertical"
                    android:orientation="horizontal" />
            </HorizontalScrollView>

            <androidx.constraintlayout.widget.ConstraintLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="20dp"
                android:layout_marginTop="28dp">

                <TextView
                    android:id="@+id/tvScreenTitle"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:fontFamily="sans-serif-condensed"
                    android:letterSpacing="0"
                    android:text="Bảng xếp hạng"
                    android:textColor="@color/stadium_ink"
                    android:textSize="25sp"
                    android:textStyle="bold|italic"
                    app:layout_constraintEnd_toStartOf="@id/tvScreenMeta"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toTopOf="parent" />

                <TextView
                    android:id="@+id/tvScreenMeta"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="BẢNG XẾP HẠNG"
                    android:textColor="@color/red_energy"
                    android:textSize="11sp"
                    android:textStyle="bold"
                    app:layout_constraintBottom_toBottomOf="@id/tvScreenTitle"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintTop_toTopOf="@id/tvScreenTitle" />

            </androidx.constraintlayout.widget.ConstraintLayout>

            <ProgressBar
                android:id="@+id/progressBar"
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:layout_gravity="center_horizontal"
                android:layout_marginTop="28dp" />

            <TextView
                android:id="@+id/tvEmptyState"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="20dp"
                android:layout_marginTop="28dp"
                android:background="@drawable/bg_match_center_card"
                android:gravity="center"
                android:padding="22dp"
                android:text="B&#7843;ng x&#7871;p h&#7841;ng s&#7869; hi&#7875;n th&#7883; khi m&#249;a gi&#7843;i c&#243; d&#7919; li&#7879;u ch&#237;nh th&#7913;c."
                android:textColor="@color/dark_gray_text"
                android:textSize="14sp"
                android:visibility="gone" />

            <LinearLayout
                android:id="@+id/tableContainer"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="20dp"
                android:layout_marginTop="18dp"
                android:background="@drawable/bg_standings_table_dark"
                android:orientation="vertical"
                android:visibility="gone">

                <androidx.constraintlayout.widget.ConstraintLayout
                    android:layout_width="match_parent"
                    android:layout_height="54dp"
                    android:background="@drawable/bg_standings_header_dark"
                    android:paddingHorizontal="12dp">

                    <TextView
                        android:id="@+id/headerPosition"
                        android:layout_width="42dp"
                        android:layout_height="wrap_content"
                        android:gravity="center"
                        android:text="HẠNG"
                        android:textColor="@color/dark_gray_text"
                        android:textSize="10sp"
                        android:textStyle="bold"
                        app:layout_constraintBottom_toBottomOf="parent"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toTopOf="parent" />

                    <TextView
                        android:id="@+id/headerClub"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="42dp"
                        android:gravity="start"
                        android:text="CLB"
                        android:textColor="@color/dark_gray_text"
                        android:textSize="10sp"
                        android:textStyle="bold"
                        app:layout_constraintBottom_toBottomOf="parent"
                        app:layout_constraintEnd_toStartOf="@id/headerPlayed"
                        app:layout_constraintStart_toEndOf="@id/headerPosition"
                        app:layout_constraintTop_toTopOf="parent" />

                    <TextView
                        android:id="@+id/headerPlayed"
                        android:layout_width="34dp"
                        android:layout_height="wrap_content"
                        android:gravity="center"
                        android:text="TR"
                        android:textColor="@color/dark_gray_text"
                        android:textSize="10sp"
                        android:textStyle="bold"
                        app:layout_constraintBottom_toBottomOf="parent"
                        app:layout_constraintEnd_toStartOf="@id/headerGoalDiff"
                        app:layout_constraintTop_toTopOf="parent" />

                    <TextView
                        android:id="@+id/headerGoalDiff"
                        android:layout_width="38dp"
                        android:layout_height="wrap_content"
                        android:gravity="center"
                        android:text="HS"
                        android:textColor="@color/dark_gray_text"
                        android:textSize="10sp"
                        android:textStyle="bold"
                        app:layout_constraintBottom_toBottomOf="parent"
                        app:layout_constraintEnd_toStartOf="@id/headerPoints"
                        app:layout_constraintTop_toTopOf="parent" />

                    <TextView
                        android:id="@+id/headerPoints"
                        android:layout_width="38dp"
                        android:layout_height="wrap_content"
                        android:gravity="end|center_vertical"
                        android:text="Đ"
                        android:textColor="@color/dark_gray_text"
                        android:textSize="10sp"
                        android:textStyle="bold"
                        app:layout_constraintBottom_toBottomOf="parent"
                        app:layout_constraintEnd_toEndOf="parent"
                        app:layout_constraintTop_toTopOf="parent" />
                </androidx.constraintlayout.widget.ConstraintLayout>

                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/rvStandings"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:nestedScrollingEnabled="false"
                    android:overScrollMode="never" />
            </LinearLayout>

            <TextView
                android:id="@+id/tvStandingLegend"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="20dp"
                android:layout_marginTop="16dp"
                android:text="Vàng: nhóm dẫn đầu / Đỏ: nhóm cuối bảng"
                android:textColor="@color/dark_gray_text"
                android:textSize="12sp"
                android:textStyle="bold" />

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

    <include
        android:id="@+id/bottomNav"
        layout="@layout/component_bottom_nav_matches" />
</FrameLayout>

