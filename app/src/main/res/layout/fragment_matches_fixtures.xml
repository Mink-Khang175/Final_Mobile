<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_screen_field">

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:clipToPadding="false"
        android:fillViewport="true"
        android:paddingBottom="180dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingBottom="28dp">

            <include
                android:id="@+id/appHeader"
                layout="@layout/component_app_header" />

            <LinearLayout
                android:id="@+id/layoutTabs"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:layout_marginHorizontal="20dp"
                android:layout_marginTop="20dp"
                android:background="@drawable/bg_segmented_tabs"
                android:orientation="horizontal"
                android:padding="4dp"
                android:weightSum="3">

                <TextView
                    android:id="@+id/tabFixtures"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:background="@drawable/bg_segment_active"
                    android:gravity="center"
                    android:text="LỊCH ĐẤU"
                    android:textColor="@color/red_energy"
                    android:textSize="12sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/tabResults"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:gravity="center"
                    android:text="KẾT QUẢ"
                    android:textColor="@color/dark_gray_text"
                    android:textSize="12sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/tabStandings"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:gravity="center"
                    android:text="BXH"
                    android:textColor="@color/dark_gray_text"
                    android:textSize="12sp"
                    android:textStyle="bold" />
            </LinearLayout>

            <androidx.constraintlayout.widget.ConstraintLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="20dp"
                android:layout_marginTop="28dp">

                <TextView
                    android:id="@+id/tvScreenTitle"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:text="Lịch sắp tới"
                    android:fontFamily="sans-serif-condensed"
                    android:letterSpacing="0"
                    android:textColor="@color/stadium_ink"
                    android:textSize="25sp"
                    android:textStyle="bold|italic"
                    app:layout_constraintEnd_toStartOf="@id/tvScreenMeta"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toTopOf="parent" />

                <TextView
                    android:id="@+id/tvScreenMeta"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="V.LEAGUE"
                    android:textColor="@color/red_energy"
                    android:textSize="11sp"
                    android:textStyle="bold"
                    app:layout_constraintBottom_toBottomOf="@id/tvScreenTitle"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintTop_toTopOf="@id/tvScreenTitle" />

                <TextView
                    android:id="@+id/tvScreenSubtitle"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="6dp"
                    android:text="L&#7883;ch thi &#273;&#7845;u ch&#237;nh th&#7913;c s&#7869; &#273;&#432;&#7907;c c&#7853;p nh&#7853;t khi m&#249;a gi&#7843;i m&#7899;i c&#244;ng b&#7889;."
                    android:textColor="@color/sports_medium_gray"
                    android:textSize="13sp"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toBottomOf="@id/tvScreenTitle" />
            </androidx.constraintlayout.widget.ConstraintLayout>

            <HorizontalScrollView
                android:id="@+id/scrollRoundFilter"
                android:layout_width="match_parent"
                android:layout_height="46dp"
                android:layout_marginTop="14dp"
                android:clipToPadding="false"
                android:overScrollMode="never"
                android:paddingStart="20dp"
                android:paddingEnd="20dp"
                android:scrollbars="none">

                <LinearLayout
                    android:id="@+id/roundInlineContainer"
                    android:layout_width="wrap_content"
                    android:layout_height="match_parent"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <TextView
                        android:id="@+id/chipRoundFilter"
                        style="@style/ShopCategoryChip"
                        android:background="@drawable/bg_shop_chip_selected"
                        android:text="Tất cả vòng ▾"
                        android:textColor="@color/white" />
                </LinearLayout>
            </HorizontalScrollView>

            <ProgressBar
                android:id="@+id/progressBar"
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:layout_gravity="center_horizontal"
                android:layout_marginTop="28dp" />

            <TextView
                android:id="@+id/tvEmptyState"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="20dp"
                android:layout_marginTop="28dp"
                android:background="@drawable/bg_match_surface"
                android:gravity="center"
                android:padding="22dp"
                android:text="Hi&#7879;n ch&#432;a c&#243; tr&#7853;n &#273;&#7845;u s&#7855;p di&#7877;n ra trong m&#249;a gi&#7843;i n&#224;y." 
                android:textColor="@color/dark_gray_text"
                android:textSize="14sp"
                android:visibility="gone" />

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rvFixtures"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="20dp"
                android:layout_marginTop="18dp"
                android:nestedScrollingEnabled="false"
                android:overScrollMode="never" />
        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

    <include
        android:id="@+id/bottomNav"
        layout="@layout/component_bottom_nav_matches" />
</FrameLayout>

