<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="56dp"
    android:layout_marginHorizontal="20dp"
    android:layout_marginTop="8dp"
    android:background="@drawable/bg_news_search"
    android:gravity="center_vertical"
    android:orientation="horizontal"
    android:paddingStart="16dp"
    android:paddingEnd="14dp">

    <androidx.appcompat.widget.AppCompatImageView
        android:layout_width="22dp"
        android:layout_height="22dp"
        android:src="@drawable/ic_search_24"
        app:tint="@color/red_energy" />

    <EditText
        android:id="@+id/etNewsSearch"
        android:layout_width="0dp"
        android:layout_height="match_parent"
        android:layout_marginStart="10dp"
        android:layout_weight="1"
        android:background="@color/transparent"
        android:hint="Tìm kiếm tin tức, CLB, cầu thủ..."
        android:imeOptions="actionSearch"
        android:inputType="text"
        android:maxLines="1"
        android:padding="0dp"
        android:singleLine="true"
        android:textColor="@color/dark_icon"
        android:textColorHint="@color/dark_gray_alpha_60"
        android:textSize="14sp" />
</LinearLayout>
