<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@drawable/bg_standing_row_dark"
    android:minHeight="66dp">

    <View
        android:id="@+id/viewZoneIndicator"
        android:layout_width="4dp"
        android:layout_height="0dp"
        android:background="@color/transparent"
        app:layout_constraintBottom_toTopOf="@id/viewRowDivider"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <TextView
        android:id="@+id/tvPosition"
        android:layout_width="42dp"
        android:layout_height="wrap_content"
        android:gravity="center"
        android:textColor="@color/dark_gray_text"
        android:textSize="13sp"
        android:textStyle="bold"
        app:layout_constraintBottom_toTopOf="@id/viewRowDivider"
        app:layout_constraintStart_toStartOf="@id/contentStartGuide"
        app:layout_constraintTop_toTopOf="parent" />

    <ImageView
        android:id="@+id/imgTeamLogo"
        android:layout_width="32dp"
        android:layout_height="32dp"
        android:layout_marginStart="6dp"
        android:contentDescription="@string/club_logo"
        android:scaleType="centerInside"
        android:src="@drawable/ic_logo"
        app:layout_constraintBottom_toBottomOf="@id/tvPosition"
        app:layout_constraintStart_toEndOf="@id/tvPosition"
        app:layout_constraintTop_toTopOf="@id/tvPosition" />

    <TextView
        android:id="@+id/tvTeamName"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="10dp"
        android:layout_marginEnd="6dp"
        android:ellipsize="none"
        android:lineSpacingExtra="1dp"
        android:maxLines="2"
        android:textColor="@color/stadium_ink"
        android:textSize="14sp"
        android:textStyle="bold"
        app:layout_constraintBottom_toBottomOf="@id/tvPosition"
        app:layout_constraintEnd_toStartOf="@id/tvPlayed"
        app:layout_constraintStart_toEndOf="@id/imgTeamLogo"
        app:layout_constraintTop_toTopOf="@id/tvPosition" />

    <TextView
        android:id="@+id/tvPlayed"
        android:layout_width="34dp"
        android:layout_height="wrap_content"
        android:gravity="center"
        android:textColor="@color/dark_gray_text"
        android:textSize="14sp"
        app:layout_constraintBottom_toBottomOf="@id/tvPosition"
        app:layout_constraintEnd_toStartOf="@id/tvGoalDiff"
        app:layout_constraintTop_toTopOf="@id/tvPosition" />

    <TextView
        android:id="@+id/tvGoalDiff"
        android:layout_width="38dp"
        android:layout_height="wrap_content"
        android:gravity="center"
        android:textColor="@color/dark_gray_text"
        android:textSize="14sp"
        app:layout_constraintBottom_toBottomOf="@id/tvPosition"
        app:layout_constraintEnd_toStartOf="@id/tvPoints"
        app:layout_constraintTop_toTopOf="@id/tvPosition" />

    <TextView
        android:id="@+id/tvPoints"
        android:layout_width="38dp"
        android:layout_height="wrap_content"
        android:gravity="end"
        android:textColor="@color/stadium_ink"
        android:textSize="15sp"
        android:textStyle="bold"
        app:layout_constraintBottom_toBottomOf="@id/tvPosition"
        app:layout_constraintEnd_toStartOf="@id/contentEndGuide"
        app:layout_constraintTop_toTopOf="@id/tvPosition" />

    <View
        android:id="@+id/viewRowDivider"
        android:layout_width="0dp"
        android:layout_height="1dp"
        android:background="#E2E8F0"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="@id/tvTeamName" />

    <androidx.constraintlayout.widget.Guideline
        android:id="@+id/contentStartGuide"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        app:layout_constraintGuide_begin="10dp" />

    <androidx.constraintlayout.widget.Guideline
        android:id="@+id/contentEndGuide"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        app:layout_constraintGuide_end="12dp" />
</androidx.constraintlayout.widget.ConstraintLayout>

