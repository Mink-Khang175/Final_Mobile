<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="12dp"
    app:cardBackgroundColor="@color/premium_card"
    app:cardCornerRadius="18dp"
    app:cardElevation="4dp"
    app:strokeColor="@color/gray_border"
    app:strokeWidth="1dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:minHeight="132dp"
        android:orientation="horizontal"
        android:padding="12dp">

        <com.google.android.material.imageview.ShapeableImageView
            android:id="@+id/imgCartProduct"
            android:layout_width="86dp"
            android:layout_height="108dp"
            android:background="@drawable/bg_shop_product_image"
            android:padding="8dp"
            android:scaleType="centerInside"
            android:src="@drawable/ic_logo"
            app:shapeAppearanceOverlay="@style/ShopProductImageShape" />

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="12dp"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:id="@+id/tvCartProductName"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:ellipsize="end"
                android:lineSpacingExtra="2dp"
                android:maxLines="2"
                android:minHeight="42dp"
                android:textColor="@color/dark_icon"
                android:textSize="13sp"
                android:textStyle="bold"
                tools:text="AO THI DAU CLB BONG DA BECAMEX TP.HCM 2025/26 MAU TIM KAMITO" />

            <TextView
                android:id="@+id/tvCartProductPrice"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:textColor="@color/shop_dynamic_red"
                android:textSize="15sp"
                android:textStyle="bold"
                tools:text="499.000d" />

            <TextView
                android:id="@+id/tvCartProductSize"
                android:layout_width="wrap_content"
                android:layout_height="26dp"
                android:layout_marginTop="6dp"
                android:background="@drawable/bg_product_size_unselected"
                android:gravity="center"
                android:paddingHorizontal="10dp"
                android:textColor="@color/dark_icon"
                android:textSize="11sp"
                android:textStyle="bold"
                tools:text="SIZE M" />

            <LinearLayout
                android:id="@+id/layoutCartQuantity"
                android:layout_width="wrap_content"
                android:layout_height="40dp"
                android:layout_marginTop="8dp"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <ImageButton
                    android:id="@+id/btnCartDecrease"
                    android:layout_width="38dp"
                    android:layout_height="38dp"
                    android:background="@drawable/bg_mini_icon_light"
                    android:contentDescription="Giảm số lượng"
                    android:padding="12dp"
                    android:src="@drawable/ic_minus_24"
                    app:tint="@color/dark_gray_text" />

                <TextView
                    android:id="@+id/tvCartQuantity"
                    android:layout_width="42dp"
                    android:layout_height="38dp"
                    android:gravity="center"
                    android:textColor="@color/dark_icon"
                    android:textSize="15sp"
                    android:textStyle="bold"
                    tools:text="1" />

                <ImageButton
                    android:id="@+id/btnCartIncrease"
                    android:layout_width="38dp"
                    android:layout_height="38dp"
                    android:background="@drawable/bg_mini_icon_light"
                    android:contentDescription="Tăng số lượng"
                    android:padding="12dp"
                    android:src="@drawable/ic_plus_24"
                    app:tint="@color/dark_gray_text" />
            </LinearLayout>
        </LinearLayout>
    </LinearLayout>
</com.google.android.material.card.MaterialCardView>
