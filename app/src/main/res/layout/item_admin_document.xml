<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="12dp"
    android:background="@drawable/bg_admin_module_card"
    android:orientation="vertical"
    android:paddingHorizontal="16dp"
    android:paddingVertical="16dp">

    <TextView
        android:id="@+id/tvDocumentTitle"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:ellipsize="end"
        android:maxLines="2"
        android:textColor="@color/stadium_ink"
        android:textSize="16sp"
        android:textStyle="bold"
        tools:text="Đơn hàng VN-2026-001" />

    <TextView
        android:id="@+id/tvDocumentBody"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="6dp"
        android:layout_marginBottom="12dp"
        android:lineSpacingExtra="4dp"
        android:textColor="@color/slate_caption"
        android:textSize="13sp"
        tools:text="Khách hàng: Nguyễn Văn A&#10;Trạng thái: Đang giao" />

    <HorizontalScrollView
        android:id="@+id/scrollActions"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:clipToPadding="false"
        android:paddingTop="2dp"
        android:overScrollMode="never"
        android:scrollbars="none">

        <LinearLayout
            android:id="@+id/layoutActions"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:baselineAligned="false"
            android:orientation="horizontal" />
    </HorizontalScrollView>
</LinearLayout>
