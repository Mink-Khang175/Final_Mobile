<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_screen_field">

    <FrameLayout
        android:id="@+id/id_video_banner"
        android:layout_width="0dp"
        android:layout_height="300dp"
        android:background="@color/navy_deep"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <androidx.media3.ui.PlayerView
            android:id="@+id/videoAuthHero"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            app:resize_mode="fill"
            app:surface_type="texture_view"
            app:use_controller="false" />

        <View
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:background="@drawable/bg_auth_hero_scrim" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:gravity="center"
            android:orientation="vertical"
            android:paddingHorizontal="24dp">

            <ImageView
                android:id="@+id/imgAuthLogo"
                android:layout_width="68dp"
                android:layout_height="68dp"
                android:contentDescription="@string/app_name"
                android:src="@drawable/ic_logo_auth" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="14dp"
                android:text="Tham gia V.League"
                android:textColor="@color/white"
                android:textSize="26sp"
                android:textStyle="bold" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:gravity="center"
                android:text="Tạo tài khoản để đặt vé, mua hàng và nhận quyền lợi CLB."
                android:textColor="@color/white_alpha_80"
                android:textSize="14sp" />
        </LinearLayout>
    </FrameLayout>

    <androidx.core.widget.NestedScrollView
        android:id="@+id/authFormScroll"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:layout_marginTop="-40dp"
        android:background="@android:color/white"
        android:clipToPadding="false"
        android:elevation="12dp"
        android:fillViewport="true"
        android:overScrollMode="never"
        android:translationZ="12dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/id_video_banner">

        <com.google.android.material.card.MaterialCardView
            android:id="@+id/cardAuthForm"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@android:color/white"
            android:elevation="12dp"
            android:translationZ="12dp"
            app:cardBackgroundColor="@android:color/white"
            app:cardCornerRadius="28dp"
            app:cardElevation="12dp"
            app:strokeWidth="0dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:minHeight="650dp"
                android:orientation="vertical"
                android:paddingHorizontal="24dp"
                android:paddingTop="30dp"
                android:paddingBottom="24dp">

                <TextView
                    android:id="@+id/tvAuthTitle"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Tạo tài khoản"
                    android:textColor="@color/stadium_ink"
                    android:textSize="22sp"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="6dp"
                    android:text="Bắt đầu hành trình bóng đá của bạn."
                    android:textColor="@color/dark_gray_text"
                    android:textSize="14sp" />

                <com.google.android.material.textfield.TextInputLayout
                    android:id="@+id/tilFullName"
                    style="@style/AuthTextInputLayout"
                    android:layout_marginTop="22dp"
                    android:hint="Họ và tên"
                    app:startIconDrawable="@drawable/ic_person_24">

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/edtFullName"
                        style="@style/AuthTextInputEditText"
                        android:inputType="textPersonName" />
                </com.google.android.material.textfield.TextInputLayout>

                <com.google.android.material.textfield.TextInputLayout
                    android:id="@+id/tilEmail"
                    style="@style/AuthTextInputLayout"
                    android:layout_marginTop="12dp"
                    android:hint="Email"
                    app:startIconDrawable="@drawable/ic_email_24">

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/edtEmail"
                        style="@style/AuthTextInputEditText"
                        android:inputType="textEmailAddress" />
                </com.google.android.material.textfield.TextInputLayout>

                <com.google.android.material.textfield.TextInputLayout
                    android:id="@+id/tilPassword"
                    style="@style/AuthTextInputLayout"
                    android:layout_marginTop="12dp"
                    android:hint="Mật khẩu"
                    app:endIconMode="password_toggle"
                    app:startIconDrawable="@drawable/ic_lock_24">

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/edtPassword"
                        style="@style/AuthTextInputEditText"
                        android:inputType="textPassword" />
                </com.google.android.material.textfield.TextInputLayout>

                <com.google.android.material.textfield.TextInputLayout
                    android:id="@+id/tilConfirmPassword"
                    style="@style/AuthTextInputLayout"
                    android:layout_marginTop="12dp"
                    android:hint="Xác nhận mật khẩu"
                    app:endIconMode="password_toggle"
                    app:startIconDrawable="@drawable/ic_lock_24">

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/edtConfirmPassword"
                        style="@style/AuthTextInputEditText"
                        android:inputType="textPassword" />
                </com.google.android.material.textfield.TextInputLayout>

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnCreateAccount"
                    android:layout_width="match_parent"
                    android:layout_height="56dp"
                    android:layout_marginTop="20dp"
                    android:text="TẠO TÀI KHOẢN"
                    android:textColor="@color/white"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    app:backgroundTint="@color/shop_dynamic_red"
                    app:cornerRadius="14dp"
                    app:elevation="0dp" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="24dp"
                    android:gravity="center"
                    android:orientation="horizontal">

                    <View
                        android:layout_width="0dp"
                        android:layout_height="1dp"
                        android:layout_weight="1"
                        android:background="@color/gray_border" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:paddingHorizontal="12dp"
                        android:text="Hoặc tiếp tục với"
                        android:textColor="@color/dark_gray_text"
                        android:textSize="12sp" />

                    <View
                        android:layout_width="0dp"
                        android:layout_height="1dp"
                        android:layout_weight="1"
                        android:background="@color/gray_border" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="50dp"
                    android:layout_marginTop="18dp"
                    android:baselineAligned="false"
                    android:orientation="horizontal">

                    <LinearLayout
                        android:id="@+id/btnGoogle"
                        style="@style/AuthSocialButton"
                        android:layout_marginEnd="6dp">

                        <ImageView
                            android:layout_width="18dp"
                            android:layout_height="18dp"
                            android:src="@drawable/ic_google_24" />

                        <TextView
                            style="@style/AuthSocialButtonText"
                            android:text="Google" />
                    </LinearLayout>

                    <LinearLayout
                        android:id="@+id/btnFacebook"
                        style="@style/AuthSocialButton"
                        android:layout_marginStart="6dp">

                        <ImageView
                            android:layout_width="18dp"
                            android:layout_height="18dp"
                            android:src="@drawable/ic_facebook_24" />

                        <TextView
                            style="@style/AuthSocialButtonText"
                            android:text="Facebook" />
                    </LinearLayout>
                </LinearLayout>

                <Space
                    android:layout_width="match_parent"
                    android:layout_height="0dp"
                    android:layout_weight="1" />

                <TextView
                    android:id="@+id/tvGoLogin"
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:gravity="center"
                    android:text="Đã có tài khoản? Đăng nhập"
                    android:textColor="@color/dark_gray_text"
                    android:textSize="14sp" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>
    </androidx.core.widget.NestedScrollView>
</androidx.constraintlayout.widget.ConstraintLayout>
