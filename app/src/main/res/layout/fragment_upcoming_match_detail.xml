<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_screen_field">

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:clipToPadding="false"
        android:fillViewport="true"
        android:overScrollMode="never"
        android:paddingBottom="180dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingBottom="28dp">

            <include
                android:id="@+id/appHeader"
                layout="@layout/component_app_header" />

            <TextView
                android:id="@+id/btnBack"
                android:layout_width="wrap_content"
                android:layout_height="38dp"
                android:layout_marginStart="20dp"
                android:layout_marginTop="14dp"
                android:background="@drawable/bg_product_size_unselected"
                android:gravity="center"
                android:paddingHorizontal="14dp"
                android:text="Quay lại"
                android:textColor="@color/stadium_ink"
                android:textSize="13sp"
                android:textStyle="bold" />

            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cardHero"
                android:layout_width="match_parent"
                android:layout_height="266dp"
                android:layout_marginHorizontal="20dp"
                android:layout_marginTop="14dp"
                app:cardBackgroundColor="@color/premium_card"
                app:cardCornerRadius="22dp"
                app:cardElevation="5dp"
                app:strokeColor="@color/sports_outline"
                app:strokeWidth="1dp">

                <FrameLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent">

                    <ImageView
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:scaleType="centerCrop"
                        android:src="@drawable/svd" />

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:background="@drawable/bg_shop_hero_scrim" />

                    <androidx.constraintlayout.widget.ConstraintLayout
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:padding="18dp">

                        <TextView
                            android:id="@+id/tvStatus"
                            android:layout_width="wrap_content"
                            android:layout_height="30dp"
                            android:background="@drawable/bg_shop_orange_pill"
                            android:gravity="center"
                            android:paddingHorizontal="12dp"
                            android:text="SẮP DIỄN RA"
                            android:textColor="@color/white"
                            android:textSize="11sp"
                            android:textStyle="bold"
                            app:layout_constraintStart_toStartOf="parent"
                            app:layout_constraintTop_toTopOf="parent" />

                        <TextView
                            android:id="@+id/tvRound"
                            android:layout_width="wrap_content"
                            android:layout_height="30dp"
                            android:background="@color/black_alpha_25"
                            android:gravity="center"
                            android:paddingHorizontal="10dp"
                            android:textColor="@color/white"
                            android:textSize="11sp"
                            android:textStyle="bold"
                            app:layout_constraintEnd_toEndOf="parent"
                            app:layout_constraintTop_toTopOf="parent"
                            tools:text="Vòng 1" />

                        <LinearLayout
                            android:id="@+id/layoutTeams"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:baselineAligned="false"
                            android:gravity="center"
                            android:orientation="horizontal"
                            app:layout_constraintBottom_toTopOf="@id/layoutMeta"
                            app:layout_constraintEnd_toEndOf="parent"
                            app:layout_constraintStart_toStartOf="parent"
                            app:layout_constraintTop_toBottomOf="@id/tvStatus">

                            <LinearLayout
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:gravity="center"
                                android:orientation="vertical">

                                <ImageView
                                    android:id="@+id/imgHomeLogo"
                                    android:layout_width="64dp"
                                    android:layout_height="64dp"
                                    android:background="@drawable/bg_home_story_ring"
                                    android:padding="8dp"
                                    android:scaleType="centerInside"
                                    android:src="@drawable/ic_logo" />

                                <TextView
                                    android:id="@+id/tvHomeName"
                                    android:layout_width="match_parent"
                                    android:layout_height="wrap_content"
                                    android:layout_marginTop="10dp"
                                    android:ellipsize="end"
                                    android:gravity="center"
                                    android:maxLines="2"
                                    android:textColor="@color/white"
                                    android:textSize="15sp"
                                    android:textStyle="bold"
                                    tools:text="Ha Noi FC" />
                            </LinearLayout>

                            <TextView
                                android:id="@+id/tvKickoffTime"
                                android:layout_width="92dp"
                                android:layout_height="62dp"
                                android:background="@drawable/bg_home_fixture_time"
                                android:gravity="center"
                                android:textColor="@color/stadium_ink"
                                android:textSize="22sp"
                                android:textStyle="bold"
                                tools:text="19:15" />

                            <LinearLayout
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:gravity="center"
                                android:orientation="vertical">

                                <ImageView
                                    android:id="@+id/imgAwayLogo"
                                    android:layout_width="64dp"
                                    android:layout_height="64dp"
                                    android:background="@drawable/bg_home_story_ring"
                                    android:padding="8dp"
                                    android:scaleType="centerInside"
                                    android:src="@drawable/ic_logo" />

                                <TextView
                                    android:id="@+id/tvAwayName"
                                    android:layout_width="match_parent"
                                    android:layout_height="wrap_content"
                                    android:layout_marginTop="10dp"
                                    android:ellipsize="end"
                                    android:gravity="center"
                                    android:maxLines="2"
                                    android:textColor="@color/white"
                                    android:textSize="15sp"
                                    android:textStyle="bold"
                                    tools:text="Nam Dinh" />
                            </LinearLayout>
                        </LinearLayout>

                        <LinearLayout
                            android:id="@+id/layoutMeta"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:gravity="center"
                            android:orientation="vertical"
                            app:layout_constraintBottom_toBottomOf="parent"
                            app:layout_constraintEnd_toEndOf="parent"
                            app:layout_constraintStart_toStartOf="parent">

                            <TextView
                                android:id="@+id/tvKickoffDate"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:gravity="center"
                                android:textColor="@color/white_alpha_85"
                                android:textSize="13sp"
                                android:textStyle="bold"
                                tools:text="Thu 7, 15/08/2026" />

                            <TextView
                                android:id="@+id/tvVenue"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="5dp"
                                android:ellipsize="end"
                                android:gravity="center"
                                android:maxLines="1"
                                android:textColor="@color/white_alpha_80"
                                android:textSize="13sp"
                                tools:text="Sân vận động Hàng Đẫy" />
                        </LinearLayout>
                    </androidx.constraintlayout.widget.ConstraintLayout>
                </FrameLayout>
            </com.google.android.material.card.MaterialCardView>

            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="20dp"
                android:layout_marginTop="14dp"
                app:cardBackgroundColor="@color/premium_card"
                app:cardCornerRadius="20dp"
                app:cardElevation="3dp"
                app:strokeColor="@color/sports_outline"
                app:strokeWidth="1dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Thông tin trước trận"
                        android:textColor="@color/stadium_ink"
                        android:textSize="18sp"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/tvPreview"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="10dp"
                        android:background="@drawable/bg_auth_field"
                        android:lineSpacingExtra="4dp"
                        android:padding="14dp"
                        android:textColor="@color/dark_gray_text"
                        android:textSize="14sp"
                        tools:text="Hai đội sẵn sàng cho vòng đầu tiên." />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="20dp"
                android:layout_marginTop="14dp"
                app:cardBackgroundColor="@color/premium_card"
                app:cardCornerRadius="20dp"
                app:cardElevation="3dp"
                app:strokeColor="@color/sports_outline"
                app:strokeWidth="1dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Sân vận động"
                        android:textColor="@color/stadium_ink"
                        android:textSize="18sp"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/tvStadiumInfo"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="10dp"
                        android:background="@drawable/bg_auth_field"
                        android:lineSpacingExtra="4dp"
                        android:padding="14dp"
                        android:textColor="@color/dark_gray_text"
                        android:textSize="14sp"
                        tools:text="Sân vận động Hàng Đẫy" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnBuyTicket"
                android:layout_width="match_parent"
                android:layout_height="54dp"
                android:layout_marginHorizontal="20dp"
                android:layout_marginTop="16dp"
                android:text="Mua vé ngay"
                android:textAllCaps="false"
                android:textColor="@color/white"
                android:textSize="15sp"
                android:textStyle="bold"
                app:backgroundTint="@color/shop_dynamic_orange"
                app:cornerRadius="14dp"
                app:elevation="0dp" />
        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

    <include
        android:id="@+id/bottomNav"
        layout="@layout/component_bottom_nav_matches" />
</FrameLayout>
