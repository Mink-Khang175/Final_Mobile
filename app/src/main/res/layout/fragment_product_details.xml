<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_home_premium_screen">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/productTopBar"
        android:layout_width="0dp"
        android:layout_height="64dp"
        android:background="@color/white"
        android:elevation="4dp"
        android:paddingHorizontal="18dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <ImageButton
            android:id="@+id/btnBack"
            android:layout_width="42dp"
            android:layout_height="42dp"
            android:background="@drawable/bg_product_top_icon"
            android:contentDescription="Quay lại"
            android:padding="10dp"
            android:scaleType="center"
            android:src="@drawable/ic_arrow_left_24"
            app:tint="@color/stadium_ink"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <TextView
            android:id="@+id/tvProductTopTitle"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="12dp"
            android:layout_marginEnd="12dp"
            android:ellipsize="end"
            android:maxLines="1"
            android:text="Chi tiết sản phẩm"
            android:textColor="@color/stadium_ink"
            android:textSize="18sp"
            android:textStyle="bold"
            app:layout_constraintBottom_toBottomOf="@id/btnBack"
            app:layout_constraintEnd_toStartOf="@id/btnCart"
            app:layout_constraintStart_toEndOf="@id/btnBack"
            app:layout_constraintTop_toTopOf="@id/btnBack" />

        <ImageButton
            android:id="@+id/btnCart"
            android:layout_width="42dp"
            android:layout_height="42dp"
            android:background="@drawable/bg_product_top_icon"
            android:contentDescription="Giỏ hàng"
            android:padding="9dp"
            android:scaleType="center"
            android:src="@drawable/ic_bag_24"
            app:tint="@color/stadium_ink"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="parent" />
    </androidx.constraintlayout.widget.ConstraintLayout>

    <androidx.core.widget.NestedScrollView
        android:id="@+id/productScroll"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:clipToPadding="false"
        android:overScrollMode="never"
        android:paddingBottom="16dp"
        app:layout_constraintBottom_toTopOf="@id/productActionPanel"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/productTopBar">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingTop="14dp"
            android:paddingBottom="18dp">

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rvProductImages"
                android:layout_width="match_parent"
                android:layout_height="292dp"
                android:clipToPadding="false"
                android:orientation="horizontal"
                android:overScrollMode="never"
                android:paddingStart="20dp"
                android:paddingEnd="8dp"
                app:layoutManager="androidx.recyclerview.widget.LinearLayoutManager"
                tools:itemCount="3"
                tools:listitem="@layout/item_product_detail_image" />

            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cardProductInfo"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="20dp"
                android:layout_marginTop="14dp"
                app:cardBackgroundColor="@color/transparent"
                app:cardCornerRadius="16dp"
                app:cardElevation="2dp"
                app:strokeColor="@color/sports_outline"
                app:strokeWidth="1dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="@drawable/bg_shop_product_card_dark"
                    android:orientation="vertical"
                    android:padding="18dp">

                    <TextView
                        android:id="@+id/tvProductBadge"
                        android:layout_width="wrap_content"
                        android:layout_height="28dp"
                        android:background="@drawable/bg_shop_chip_selected"
                        android:gravity="center"
                        android:paddingHorizontal="12dp"
                        android:text="HÀNG CHÍNH HÃNG"
                        android:textColor="@color/white"
                        android:textSize="11sp"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/tvProductName"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="14dp"
                        android:lineSpacingExtra="3dp"
                        android:textColor="@color/stadium_ink"
                        android:textSize="22sp"
                        android:textStyle="bold"
                        tools:text="AO THI DAU CLB BONG DA BECAMEX TP.HCM 2025/26 MAU XANH KAMITO" />

                    <TextView
                        android:id="@+id/tvProductPrice"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="10dp"
                        android:textColor="@color/red_energy"
                        android:textSize="26sp"
                        android:textStyle="bold"
                        tools:text="499.000d" />

                    <TextView
                        android:id="@+id/tvStockStatus"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="12dp"
                        android:background="@drawable/bg_product_stock_warning"
                        android:paddingHorizontal="14dp"
                        android:paddingVertical="10dp"
                        android:text="Sản phẩm đã hết hàng"
                        android:textColor="@color/red_energy"
                        android:textSize="13sp"
                        android:textStyle="bold"
                        android:visibility="gone"
                        tools:visibility="visible" />

                    <LinearLayout
                        android:id="@+id/layoutSizeSelector"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="18dp"
                        android:orientation="vertical">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:gravity="center_vertical"
                            android:orientation="horizontal">

                            <TextView
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:text="Chọn size"
                                android:textColor="@color/stadium_ink"
                                android:textSize="15sp"
                                android:textStyle="bold" />

                            <TextView
                                android:id="@+id/tvSizeHint"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Bắt buộc"
                                android:textColor="@color/dark_gray_text"
                                android:textSize="12sp"
                                android:textStyle="bold" />
                        </LinearLayout>

                        <LinearLayout
                            android:id="@+id/layoutSizeOptions"
                            android:layout_width="match_parent"
                            android:layout_height="44dp"
                            android:layout_marginTop="10dp"
                            android:gravity="center_vertical"
                            android:orientation="horizontal"
                            android:weightSum="5">

                            <TextView
                                android:id="@+id/sizeS"
                                style="@style/ProductSizeOption"
                                android:text="S" />

                            <TextView
                                android:id="@+id/sizeM"
                                style="@style/ProductSizeOption"
                                android:text="M" />

                            <TextView
                                android:id="@+id/sizeL"
                                style="@style/ProductSizeOption"
                                android:text="L" />

                            <TextView
                                android:id="@+id/sizeXl"
                                style="@style/ProductSizeOption"
                                android:text="XL" />

                            <TextView
                                android:id="@+id/sizeXxl"
                                style="@style/ProductSizeOption"
                                android:text="XXL" />
                        </LinearLayout>
                    </LinearLayout>

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:layout_marginTop="18dp"
                        android:background="@color/gray_border" />

                    <TextView
                        android:id="@+id/tvProductDescriptionTitle"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="16dp"
                        android:text="Thông tin sản phẩm"
                        android:textColor="@color/stadium_ink"
                        android:textSize="17sp"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/tvProductDescription"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:lineSpacingExtra="4dp"
                        android:textColor="@color/dark_gray_text"
                        android:textSize="14sp"
                        tools:text="Official V.League jersey with breathable fabric and club crest." />

                    <LinearLayout
                        android:id="@+id/layoutQuantity"
                        android:layout_width="match_parent"
                        android:layout_height="52dp"
                        android:layout_marginTop="18dp"
                        android:gravity="center_vertical"
                        android:orientation="horizontal">

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="Số lượng"
                            android:textColor="@color/stadium_ink"
                            android:textSize="15sp"
                            android:textStyle="bold" />

                        <ImageButton
                            android:id="@+id/btnDecreaseQuantity"
                            android:layout_width="42dp"
                            android:layout_height="42dp"
                            android:background="@drawable/bg_mini_icon_light"
                            android:contentDescription="Giảm số lượng"
                            android:src="@drawable/ic_minus_24"
                            app:tint="@color/dark_gray_text"
                            android:padding="14dp" />

                        <TextView
                            android:id="@+id/tvQuantity"
                            android:layout_width="46dp"
                            android:layout_height="42dp"
                            android:gravity="center"
                            android:text="1"
                            android:textColor="@color/dark_icon"
                            android:textSize="17sp"
                            android:textStyle="bold" />

                        <ImageButton
                            android:id="@+id/btnIncreaseQuantity"
                            android:layout_width="42dp"
                            android:layout_height="42dp"
                            android:background="@drawable/bg_mini_icon_light"
                            android:contentDescription="Tăng số lượng"
                            android:padding="14dp"
                            android:src="@drawable/ic_plus_24"
                            app:tint="@color/dark_gray_text" />
                    </LinearLayout>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <TextView
                android:id="@+id/tvProductError"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="20dp"
                android:layout_marginTop="12dp"
                android:textColor="@color/shop_dynamic_red"
                android:textSize="13sp"
                android:visibility="gone"
                tools:text="Could not load full product details."
                tools:visibility="visible" />
        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

    <ProgressBar
        android:id="@+id/progressProductDetail"
        android:layout_width="44dp"
        android:layout_height="44dp"
        android:indeterminateTint="@color/shop_dynamic_red"
        android:visibility="gone"
        app:layout_constraintBottom_toBottomOf="@id/productScroll"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="@id/productScroll"
        tools:visibility="visible" />

    <com.google.android.material.card.MaterialCardView
        android:id="@+id/productActionPanel"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        app:cardBackgroundColor="@color/transparent"
        app:cardCornerRadius="0dp"
        app:cardElevation="8dp"
        app:strokeColor="@color/sports_outline"
        app:strokeWidth="0dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        >

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_product_bottom_panel"
            android:orientation="horizontal"
            android:paddingHorizontal="20dp"
            android:paddingTop="14dp"
            android:paddingBottom="20dp">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnAddToCart"
                style="@style/Widget.VLeague.Button.Outlined"
                android:layout_width="0dp"
                android:layout_height="56dp"
                android:layout_marginEnd="10dp"
                android:layout_weight="1"
                android:text="THÊM VÀO GIỎ"
                android:textAllCaps="false"
                android:textColor="@color/red_energy"
                android:textSize="13sp"
                android:textStyle="bold"
                app:backgroundTint="@color/white"
                app:cornerRadius="10dp"
                app:strokeColor="@color/red_energy"
                app:strokeWidth="1dp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnBuyNow"
                android:layout_width="0dp"
                android:layout_height="56dp"
                android:layout_marginStart="10dp"
                android:layout_weight="1"
                android:text="MUA NGAY"
                android:textAllCaps="false"
                android:textColor="@color/white"
                android:textSize="13sp"
                android:textStyle="bold"
                app:backgroundTint="@color/red_energy"
                app:cornerRadius="10dp"
                app:elevation="0dp" />
        </LinearLayout>
    </com.google.android.material.card.MaterialCardView>
</androidx.constraintlayout.widget.ConstraintLayout>
